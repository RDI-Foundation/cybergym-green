{
  manifest_version: "0.1.0",
  experimental_features: ["docker"],

  // TODO: Declare all config your agent needs from the deployer
  // Use secret: true for sensitive values like API keys
  config_schema: {
    type: "object",
    properties: {
    },
    required: [],
    additionalProperties: false,
  },

  // External services this agent uses
  slots: {
    proxy: { kind: "a2a" },
  },

  // Amber doesn't have a way to bind a framework capability to self, so put
  // the program into a child component.
  components: {
    program: {
      manifest: "./amber-manifest-program.json5",
      config: {},
    },
  },

  bindings: [
    { to: "#program.proxy", from: "slots.proxy" },
    { to: "#program.docker", from: "framework.docker" },
  ],

  // Capabilities exposed to the scenario
  exports: {
    a2a: "#program.a2a",
  },

  // TODO: Describe the assessment request your green agent receives
  metadata: {
    assessment_config: { task: "arvo:47101", level: "level1" }, // replace with your default assessment parameters, e.g. {"num_rounds": 2}
    participant_roles: ["agent"], // list the roles your green agent expects, e.g. ["pro_debater", "con_debater"]
  },
}
